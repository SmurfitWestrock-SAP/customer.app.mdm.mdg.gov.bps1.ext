<!-- Use stable and unique IDs!-->
<core:FragmentDefinition id="IdBTCustFrag" xmlns:core='sap.ui.core' xmlns='sap.m' xmlns:uxap='sap.uxap'
    core:require="{Time: 'sap/ui/model/odata/type/Time'}" xmlns:tab='sap.ui.table'
    xmlns:smartForm="sap.ui.comp.smartform" xmlns:smartfield="sap.ui.comp.smartfield">
    <uxap:ObjectPageSubSection id="IdCreditSubSect" title="{i18n>credmgt.tit}" mode="Expanded" titleUppercase="false"
        visible="{BPCustCreditMgtTab}">
        <uxap:blocks>
            <VBox width="100%" id="IdVBoxCredit" alignItems="Start">
                <!-- SmartForm -->
                <smartForm:SmartForm id="IdRiskClassSF" editable="true">
                    <smartForm:Group id="IdRiskClassGroup">
                        <smartForm:GroupElement id="IdRiskClassGroupElem">
                            <smartfield:SmartField id="IdRiskClassField" value="{ZZ1_RISK_CLASS_bus}" />
                        </smartForm:GroupElement>
                        <smartForm:GroupElement id="IdCreditGroupElem">
                            <smartfield:SmartField id="IdCreditGroupField" value="{ZZ1_CREDIT_GROUP_bus}" />
                        </smartForm:GroupElement>
                    </smartForm:Group>
                </smartForm:SmartForm>

                <!-- Table -->
                <tab:Table id="IdCreditCustTab" selectionMode="Single" rows="{path: 'ZC_PARTNER_MDG>to_CustCreditMgt'}"
                    enableColumnFreeze="false" enableCellFilter="false" ariaLabelledBy="title" enableSelectAll="false"
                    width="90%" visibleRowCount="4" selectionBehavior="RowOnly">
                    <tab:extension>
                        <OverflowToolbar id="IdCredToolB">
                            <Title id="IdTitTabCred" text="{i18n>bktyp.bktyp}" level="H2" />
                            <ToolbarSpacer id="IdCredToolBS" />
                            <Button id="IdCredAdd" text="{i18n>CREATE_OBJECT}" visible="{uiExt>editable}"
                                press=".extension.customer.app.mdm.mdg.gov.bps1.ext.mdgextension001.onCredMgtAdd" />
                            <Button id="IdCredUpd" text="{i18n>update}" visible="{uiExt>editable}"
                                press=".extension.customer.app.mdm.mdg.gov.bps1.ext.mdgextension001.onCredMgtUpd" />
                            <Button id="IdCredDel" text="{i18n>DELETE}" visible="{uiExt>editable}"
                                press=".extension.customer.app.mdm.mdg.gov.bps1.ext.mdgextension001.onItemDel" />
                        </OverflowToolbar>
                    </tab:extension>
                    <tab:columns>
                        <tab:Column id="IdCredCustC01">
                            <Text id="IdCredCustT01" text="{i18n>credmgt.segment}" />
                            <tab:template>
                                <Text id="IdCredCustF01" text="{ZC_PARTNER_MDG>CreditSegmentName}" />
                            </tab:template>
                        </tab:Column>
                        <tab:Column id="IdCredCustC02">
                            <Text id="IdCredCustT02" text="{i18n>credmgt.manager}" />
                            <tab:template>
                                <Text id="IdCredCustF02"
                                    text="{ZC_PARTNER_MDG>CreditManager} - {ZC_PARTNER_MDG>CreditManagerName}" />
                            </tab:template>
                        </tab:Column>
                        <tab:Column id="IdCredCustC03">
                            <Text id="IdCredCustT03" text="{i18n>credmgt.limit}" />
                            <tab:template>
                                <ObjectNumber id="IdCredCustF03"
                                    number="{ parts:[{path:'ZC_PARTNER_MDG>CreditLimit'},{path:'ZC_PARTNER_MDG>CreditSegmentCurrency'}], type: 'sap.ui.model.type.Currency', formatOptions: {showMeasure: false}}"
                                    unit="{ZC_PARTNER_MDG>CreditSegmentCurrency}" />
                            </tab:template>
                        </tab:Column>
                        <tab:Column id="IdCredCustC04">
                            <Text id="IdCredCustT04" text="{i18n>credmgt.limit.recommended}" />
                            <tab:template>
                                <ObjectNumber id="IdCredCustF04"
                                    number="{ parts:[{path:'ZC_PARTNER_MDG>RecoCreditLimitAmt'},{path:'ZC_PARTNER_MDG>RecoCreditLimitCurr'}], type: 'sap.ui.model.type.Currency', formatOptions: {showMeasure: false}}"
                                    unit="{ZC_PARTNER_MDG>RecoCreditLimitCurr}" />
                            </tab:template>
                        </tab:Column>
                        <tab:Column id="IdCredCustC05">
                            <Text id="IdCredCustT05" text="{i18n>credmgt.limit.institution}" />
                            <tab:template>
                                <Text id="IdCredCustF05"
                                    text="{ZC_PARTNER_MDG>RecoCreditLimitType} - {ZC_PARTNER_MDG>RecoCreditLimitTypeName}" />
                            </tab:template>
                        </tab:Column>
                        <tab:Column id="IdCredCustC06">
                            <Text id="IdCredCustT06" text="{i18n>credmgt.info.number}" />
                            <tab:template>
                                <Text id="IdCredCustF06"
                                    text="{ZC_PARTNER_MDG>CreditInfNumber} - {ZC_PARTNER_MDG>CreditInfText}" />
                            </tab:template>
                        </tab:Column>
                        <tab:Column id="IdCredCustC07">
                            <Text id="IdCredCustT07" text="{i18n>credmgt.insured.amount}" />
                            <tab:template>
                                <ObjectNumber id="IdCredCustF07"
                                    number="{ parts:[{path:'ZC_PARTNER_MDG>InsuredAmt'},{path:'ZC_PARTNER_MDG>InsuredCurr'}], type: 'sap.ui.model.type.Currency', formatOptions: {showMeasure: false}}"
                                    unit="{ZC_PARTNER_MDG>InsuredCurr}" />
                            </tab:template>
                        </tab:Column>
                        <tab:Column id="IdCredCustC08">
                            <Text id="IdCredCustT08" text="{i18n>credmgt.institution.insured}" />
                            <tab:template>
                                <Text id="IdCredCustF08"
                                    text="{ZC_PARTNER_MDG>InsuredType} - {ZC_PARTNER_MDG>InsuredTypeName}" />
                            </tab:template>
                        </tab:Column>
                        <tab:Column id="IdCredCustC09">
                            <Text id="IdCredCustT09" text="{i18n>credmgt.special.attention}" />
                            <tab:template>
                                <CheckBox id="IdCredCustF09" selected="{ZC_PARTNER_MDG>SpecAttRequired}" />
                            </tab:template>
                        </tab:Column>
                        <tab:Column id="IdCredCustC10">
                            <Text id="IdCredCustT10" text="{i18n>credmgt.blocked}" />
                            <tab:template>
                                <CheckBox id="IdCredCustF10" selected="{ZC_PARTNER_MDG>Blocked}" />
                            </tab:template>
                        </tab:Column>
                        <tab:Column id="IdCredCustC11">
                            <Text id="IdCredCustT11" text="{i18n>credmgt.blocking.reason}" />
                            <tab:template>
                                <Text id="IdCredCustF11"
                                    text="{ZC_PARTNER_MDG>BlockReason} - {ZC_PARTNER_MDG>BlockReasonDescription}" />
                            </tab:template>
                        </tab:Column>
                    </tab:columns>
                </tab:Table>
            </VBox>
        </uxap:blocks>
    </uxap:ObjectPageSubSection>

    <uxap:ObjectPageSubSection id="BkTypSubSectCust" title="{i18n>bktyp.cust}" mode="Expanded" titleUppercase="false">
        <tab:Table id="IdBkTypCustTab" selectionMode="Single" rows="{path: 'ZC_PARTNER_MDG>to_CustomerBankType'}"
            enableColumnFreeze="false" enableCellFilter="false" ariaLabelledBy="title" enableSelectAll="false"
            width="70%" visibleRowCount="4" selectionBehavior="RowOnly">
            <tab:extension>
                <OverflowToolbar id="IdBkTCToolB">
                    <Title id="IdTitTabC" text="{i18n>bktyp.bktyp}" level="H2" />
                    <ToolbarSpacer id="IdBkTCToolBS" />
                    <Button id="IdkTyCAdd" text="{i18n>CREATE_OBJECT}" visible="{uiExt>editable}"
                        press=".extension.customer.app.mdm.mdg.gov.bps1.ext.mdgextension001.onBkTyCAdd" />
                    <Button id="IdkTyCUpd" text="{i18n>update}" visible="{uiExt>editable}"
                        press=".extension.customer.app.mdm.mdg.gov.bps1.ext.mdgextension001.onBkTyCUpd" />
                    <Button id="IdkTyCDel" text="{i18n>DELETE}" visible="{uiExt>editable}"
                        press=".extension.customer.app.mdm.mdg.gov.bps1.ext.mdgextension001.onItemDel" />
                </OverflowToolbar>
            </tab:extension>
            <tab:columns>
                <tab:Column id="IdBkCC04">
                    <Text id="IdBkCT04" text="{i18n>bktyp.bktyp}" />
                    <tab:template>
                        <Text id="IdBkCTypF" text="{ZC_PARTNER_MDG>BankType}" />
                    </tab:template>
                </tab:Column>
                <tab:Column id="IdBkCC01">
                    <Text id="IdBkCT01" text="{i18n>bktyp.comp}" />
                    <tab:template>
                        <Text id="IdBkCComp" text="{ZC_PARTNER_MDG>CompanyCodeName} ({ZC_PARTNER_MDG>CompanyCode})"
                            visible="{=${ZC_PARTNER_MDG>CompanyCode} ? true:false}" />
                    </tab:template>
                </tab:Column>
                <tab:Column id="IdBkCC02">
                    <Text id="IdBkCT02" text="{i18n>bktyp.ba}" />
                    <tab:template>
                        <Text id="IdBkCBa" text="{ZC_PARTNER_MDG>BusinessArea}" />
                    </tab:template>
                </tab:Column>
                <tab:Column id="IdBkCC03">
                    <Text id="IdBkCT03" text="{i18n>bktyp.curr}" />
                    <tab:template>
                        <Text id="IdBkCWae" text="{ZC_PARTNER_MDG>Currency} - {ZC_PARTNER_MDG>CurrencyName}" />
                    </tab:template>
                </tab:Column>
            </tab:columns>
        </tab:Table>
    </uxap:ObjectPageSubSection>

    <uxap:ObjectPageSubSection id="BkPermiPayeeCust" title="{i18n>perpay.cust}" mode="Expanded" titleUppercase="false">
        <tab:Table id="IdPermiPayeeCustTab" selectionMode="Single"
            rows="{path: 'ZC_PARTNER_MDG>to_CustomerPermittedPayee'}" enableColumnFreeze="false"
            enableCellFilter="false" ariaLabelledBy="title" enableSelectAll="false" width="70%" visibleRowCount="4"
            selectionBehavior="RowOnly">
            <tab:extension>
                <OverflowToolbar id="IdPPCTVToolB">
                    <Title id="IdTitTabPPC" text="{i18n>perpay.perpar}" level="H2" />
                    <ToolbarSpacer id="IdPPCToolBS" />
                    <Button id="IdPPCAdd" text="{i18n>CREATE_OBJECT}" visible="{uiExt>editable}"
                        press=".extension.customer.app.mdm.mdg.gov.bps1.ext.mdgextension001.onPPCAdd" />
                    <Button id="IdPPCUpd" text="{i18n>update}" visible="{uiExt>editable}"
                        press=".extension.customer.app.mdm.mdg.gov.bps1.ext.mdgextension001.onPPCUpd" />
                    <Button id="IdPPCDel" text="{i18n>DELETE}" visible="{uiExt>editable}"
                        press=".extension.customer.app.mdm.mdg.gov.bps1.ext.mdgextension001.onItemDel" />
                </OverflowToolbar>
            </tab:extension>
            <tab:columns>
                <tab:Column id="IdPPCC01">
                    <Text id="IdPPCT01" text="{i18n>perpay.com}" />
                    <tab:template>
                        <Text id="IdPPCComp" text="{ZC_PARTNER_MDG>CompanyCodeName} ({ZC_PARTNER_MDG>CompanyCode})"
                            visible="{=${ZC_PARTNER_MDG>CompanyCode} ? true:false}" />
                    </tab:template>
                </tab:Column>
                <tab:Column id="IdPPCC02">
                    <Text id="IdPPCT02" text="{i18n>perpay.perpar}" />
                    <tab:template>
                        <Text id="IdPPCPayee"
                            text="{ZC_PARTNER_MDG>PermittedPayee} ({ZC_PARTNER_MDG>PermittedPayeeName})" />
                    </tab:template>
                </tab:Column>
            </tab:columns>
        </tab:Table>
    </uxap:ObjectPageSubSection>


    <uxap:ObjectPageSubSection id="BkUnloadPtCust" title="{i18n>unloadpt.cust}" mode="Expanded" titleUppercase="false">
        <tab:Table id="IdUnloadPtCusTab" selectionMode="Single" rows="{path: 'ZC_PARTNER_MDG>to_CustomerUnloadPoint'}"
            enableColumnFreeze="false" enableCellFilter="false" ariaLabelledBy="title" enableSelectAll="false"
            width="100%" visibleRowCount="4" selectionBehavior="RowOnly">
            <tab:extension>
                <OverflowToolbar id="IdUPCToolB">
                    <Title id="IdTitTabUPC" text="{i18n>unloadpt.cust}" level="H2" />
                    <ToolbarSpacer id="IdUPCToolBS" />
                    <Button id="IdUPCAdd" text="{i18n>CREATE_OBJECT}" visible="{uiExt>editable}"
                        press=".extension.customer.app.mdm.mdg.gov.bps1.ext.mdgextension001.onUPCAdd" />
                    <Button id="IdUPCUpd" text="{i18n>update}" visible="{uiExt>editable}"
                        press=".extension.customer.app.mdm.mdg.gov.bps1.ext.mdgextension001.onUPCUpd" />
                    <Button id="IdUPCDel" text="{i18n>DELETE}" visible="{uiExt>editable}"
                        press=".extension.customer.app.mdm.mdg.gov.bps1.ext.mdgextension001.onItemDel" />
                </OverflowToolbar>
            </tab:extension>
            <tab:columns>
                <tab:Column id="IdUPCC01">
                    <Text id="IdUPCT01" text="{i18n>unloadpt.unlpt}" />
                    <tab:template>
                        <Text id="IdUPCUnlPt" text="{ZC_PARTNER_MDG>UnloadingPointName}" />
                    </tab:template>
                </tab:Column>
                <tab:Column id="IdUPCC02">
                    <Text id="IdUPCT02" text="{i18n>unloadpt.def}" />
                    <tab:template>
                        <CheckBox id="IdUPDef" selected="{ZC_PARTNER_MDG>IsDfltBPUnloadingPoint}" enabled="false" />
                    </tab:template>
                </tab:Column>
                <tab:Column id="IdUPCC03">
                    <Text id="IdUPCT03" text="{i18n>unloadpt.cal}" />
                    <tab:template>
                        <Text id="IdUPCCal" text="{ZC_PARTNER_MDG>CustomerFactoryCalenderCode}" />
                    </tab:template>
                </tab:Column>
                <tab:Column id="IdUPCC11">
                    <Text id="IdUPCT11" text="{i18n>unloadpt.hrs}" />
                    <tab:template>
                        <Text id="idUPCHour" text="{ZC_PARTNER_MDG>BPGoodsReceivingHoursCode}" />
                    </tab:template>
                </tab:Column>
                <tab:Column id="IdUPCC04">
                    <Text id="IdUPCT04" text="{i18n>unloadpt.mon}" />
                    <tab:template>
                        <Text id="IdUPCMon"
                            text="{path: 'ZC_PARTNER_MDG>MondayMorningOpeningTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}-{path: 'ZC_PARTNER_MDG>MondayMorningClosingTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}
                            {path: 'ZC_PARTNER_MDG>MondayAfternoonOpeningTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}-{path: 'ZC_PARTNER_MDG>MondayAfternoonClosingTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}" />
                    </tab:template>
                </tab:Column>
                <tab:Column id="IdUPCC05">
                    <Text id="IdUPCT05" text="{i18n>unloadpt.tues}" />
                    <tab:template>
                        <Text id="IdUPCTues"
                            text="{path: 'ZC_PARTNER_MDG>TuesdayMorningOpeningTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}-{path: 'ZC_PARTNER_MDG>TuesdayMorningClosingTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}
                            {path: 'ZC_PARTNER_MDG>TuesdayAfternoonOpeningTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}-{path: 'ZC_PARTNER_MDG>TuesdayAfternoonClosingTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}" />
                    </tab:template>
                </tab:Column>
                <tab:Column id="IdUPCC06">
                    <Text id="IdUPCT06" text="{i18n>unloadpt.wedn}" />
                    <tab:template>
                        <Text id="IdUPCWedn"
                            text="{path: 'ZC_PARTNER_MDG>WednesdayMorningOpeningTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}-{path: 'ZC_PARTNER_MDG>WednesdayMorningClosingTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}
                            {path: 'ZC_PARTNER_MDG>WednesdayAfternoonOpeningTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}-{path: 'ZC_PARTNER_MDG>WednesdayAfternoonClosingTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}" />
                    </tab:template>
                </tab:Column>
                <tab:Column id="IdUPCC07">
                    <Text id="IdUPCT07" text="{i18n>unloadpt.thur}" />
                    <tab:template>
                        <Text id="IdUPCCThur"
                            text="{path: 'ZC_PARTNER_MDG>ThursdayMorningOpeningTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}-{path: 'ZC_PARTNER_MDG>ThursdayMorningClosingTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}
                            {path: 'ZC_PARTNER_MDG>ThursdayAfternoonOpeningTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}-{path: 'ZC_PARTNER_MDG>ThursdayAfternoonClosingTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}" />
                    </tab:template>
                </tab:Column>
                <tab:Column id="IdUPCC08">
                    <Text id="IdUPCT08" text="{i18n>unloadpt.fri}" />
                    <tab:template>
                        <Text id="IdUPCCFri"
                            text="{path: 'ZC_PARTNER_MDG>FridayMorningOpeningTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}-{path: 'ZC_PARTNER_MDG>FridayMorningClosingTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}
                            {path: 'ZC_PARTNER_MDG>FridayAfternoonOpeningTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}-{path: 'ZC_PARTNER_MDG>FridayAfternoonClosingTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}" />
                    </tab:template>
                </tab:Column>
                <tab:Column id="IdUPCC98">
                    <Text id="IdUPCT09" text="{i18n>unloadpt.sat}" />
                    <tab:template>
                        <Text id="IdUPCCSat"
                            text="{path: 'ZC_PARTNER_MDG>SaturdayMorningOpeningTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}-{path: 'ZC_PARTNER_MDG>SaturdayMorningClosingTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}
                            {path: 'ZC_PARTNER_MDG>SaturdayAfternoonOpeningTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}-{path: 'ZC_PARTNER_MDG>SaturdayAfternoonClosingTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}" />
                    </tab:template>
                </tab:Column>
                <tab:Column id="IdUPCC10">
                    <Text id="IdUPCT10" text="{i18n>unloadpt.sun}" />
                    <tab:template>
                        <Text id="IdUPCSun"
                            text="{path: 'ZC_PARTNER_MDG>SundayMorningOpeningTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}-{path: 'ZC_PARTNER_MDG>SundayMorningClosingTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}
                            {path: 'ZC_PARTNER_MDG>SundayAfternoonOpeningTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}-{path: 'ZC_PARTNER_MDG>SundayAfternoonClosingTime', type: 'sap/ui/model/odata/type/Time', formatOptions: { style: 'short' }}" />
                    </tab:template>
                </tab:Column>
            </tab:columns>
        </tab:Table>
    </uxap:ObjectPageSubSection>

</core:FragmentDefinition>